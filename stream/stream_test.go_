func TestStreamGroups(t *testing.T) {
	s := NewEngine(nil)

	err := s.LoadString(testDoc1)
	if err != nil {
		t.Error(err)
	}

	matrix := s.Run()
	for i, row := range matrix.Matrix {
		fmt.Println(i, row.String())
	}
}

